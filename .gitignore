# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
frontend/dist/
backend/dist/

# prisma generated client
backend/src/generated/
backend/prisma/generated/

# real (non-template) config — secrets live here, never commit
backend/config/config.local.yml
backend/config/config.prod.yml
backend/config/config.yml

# uploads (user avatars) — runtime artifacts, served statically
backend/uploads/

# logs
*.log
logs/
npm-debug.log*

# env
.env
.env.*

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp

# 反屏蔽：部分开发者全局 gitignore 含 macOS 的 `Icon` 规则（自定义文件夹图标），
# 会误伤同名的 Icon 组件目录，导致干净 clone 构建全红（见 issue #2）。
!frontend/src/components/Icon/

# taro
frontend/.temp/
frontend/.swc/

# wechat miniprogram upload private key (secret)
*.key
frontend/ci/private.*.key

# wechat devtools private/local project config (per-machine, not for repo)
frontend/project.private.config.json
